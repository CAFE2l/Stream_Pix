PORT=3001
NODE_ENV=development

# Firebase Admin (Secret File ou variáveis)
# Opção 1: Secret File no Render
GOOGLE_APPLICATION_CREDENTIALS=firebase-key.json

# Opção 2: Variáveis individuais
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Pix Provider: mock (dev) ou mercadopago (produção)
PIX_PROVIDER=mock

# Mercado Pago (produção) - https://www.mercadopago.com.br/developers
MERCADO_PAGO_ACCESS_TOKEN=

# Crypto USDT (TRC-20) - Crie conta em https://app.tronpro.net
# Gere um endereço TRON e coloque aqui
TRON_USDT_ADDRESS=
# API Key da TRON Grid (gratuita em https://app.tronpro.net)
TRONGRID_API_KEY=

# Segurança
ADMIN_SECRET=dev-secret-token
WEBHOOK_SECRET=

# CORS
FRONTEND_URL=http://localhost:5173
